{
  "compileOnSave": true,
  "compilerOptions": {
    "allowJs": true,  
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "packages/*/.eslintrc.cjs",
    "packages/*/config.example.ts",
    "packages/*/vitest.setup.ts",
    "packages/*/vite.config.ts",
    "packages/*/vitest.config.ts",
    "packages/*/runner.config.ts",
    "runner.config.ts",
    "vitest.workspace.ts",
    "vitest.config.ts",
    "commitlint.config.cjs"
  ],
}
