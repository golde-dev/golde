{
  "name": "@tenacify/root",
  "packageManager": "yarn@4.1.1",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "runner start",
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "lerna": "lerna",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "yarn lint:fix"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.25",
    "@chyzwar/runner": "^0.4.26",
    "@commitlint/cli": "^19.2.0",
    "@commitlint/config-conventional": "^19.1.0",
    "@lerna-lite/cli": "^3.3.1",
    "@lerna-lite/publish": "^3.3.1",
    "@lerna-lite/version": "^3.3.1",
    "@types/node": "^20.11.28",
    "@vitest/coverage-v8": "^1.4.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^27.9.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "typescript": "^5.4.2"
  }
}
