{
  "name": "@tenacify/root",
  "packageManager": "yarn@4.0.2",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "lerna": "lerna",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "pkg:cli": "pkg ./lib/bin/deployer.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "yarn lint:fix"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.24",
    "@chyzwar/runner": "^0.4.25",
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.2",
    "@lerna-lite/cli": "^3.3.0",
    "@lerna-lite/publish": "^3.3.0",
    "@lerna-lite/version": "^3.3.0",
    "@types/node": "^20.11.20",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/coverage-v8": "^1.3.1",
    "@yao-pkg/pkg": "^5.11.4",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
