{
  "name": "@tenacify/deployer",
  "packageManager": "yarn@4.0.2",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "postinstall": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "yarn lint:fix"
  },
  "dependencies": {
    
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.17",
    "@chyzwar/runner": "^0.4.18",
    "@commitlint/cli": "^18.5.0",
    "@commitlint/config-conventional": "^18.5.0",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nodemailer": "^6.9.8",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
