{
  "name": "@golde/agent",
  "version": "0.1.0",
  "exports": {},
  "tasks": {
    "start": "deno run --watch --allow-net --allow-read --allow-env src/bin/agent.ts start",
    "dist": "deno task compile",
    "dist:dev": "deno task compile",
    "publish": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts",
    "publish:dev": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts --dev",
    "compile": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run --allow-net compile.ts",
    "compile:dev": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run --allow-net compile.ts --dev"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/testing": "jsr:@std/testing@^1.0.15",
    "@std/expect": "jsr:@std/expect@^1.0.15",

    "@systemd-js/conf": "npm:@systemd-js/conf@^0.10.0",
    "@systemd-js/ctl": "npm:@systemd-js/ctl@^0.10.0",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.859.0",
    "@inquirer/prompts": "npm:@inquirer/prompts@^7.6.0",

    "commander": "npm:commander@^14.0.0",
    "pino": "npm:pino@^9.7.0",
    "pino-pretty": "npm:pino-pretty@^13.1.1",
    "zod": "npm:zod@^4.0.14"
  }
}