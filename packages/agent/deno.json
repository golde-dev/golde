{
  "name": "@golde/agent",
  "version": "0.1.0",
  "exports": {},
  "tasks": {
    "start": "deno run --watch --allow-net --allow-read --allow-env src/bin/agent.ts start",
    "dist": "deno task compile",
    "dist:local": "deno task compile",
    "publish": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts",
    "publish:local": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts --local",
    "compile": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run --allow-net compile.ts",
    "compile:local": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run --allow-net compile.ts --local"
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.23.0",
    "@inquirer/prompts": "npm:@inquirer/prompts@^5.0.1",
    "@std/archive": "jsr:@std/archive@^0.224.0",
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/cli": "jsr:@std/cli@^1.0.6",
    "@std/fs": "jsr:@std/fs@^1.0.4",
    "@std/log": "jsr:@std/log@^0.224.8",
    "@std/testing": "jsr:@std/testing@^1.0.3",
    "@systemd-js/conf": "npm:@systemd-js/conf@^0.10.0",
    "@systemd-js/ctl": "npm:@systemd-js/ctl@^0.10.0",
    "commander": "npm:commander@^12.1.0",
    "sudo-prompt": "npm:sudo-prompt@^9.2.1",
    "zod": "npm:zod@^3.23.4"
  }
}