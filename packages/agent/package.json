{
  "name": "@tenacify/agent",
  "packageManager": "yarn@4.0.2",
  "type": "commonjs",
  "version": "0.2.0",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/sensible": "5.5.0",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.25",
    "@chyzwar/runner": "^0.4.26",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitest/coverage-v8": "^1.4.0",
    "@yao-pkg/pkg": "^5.11.5",
    "eslint": "^8.57.0",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0",
    "esbuild": "^0.20.2"
  }
}
