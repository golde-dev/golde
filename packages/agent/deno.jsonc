{
  "name": "@deployer/agent",
  "version": "0.1.0",
  "tasks": {
    "start": "deno run --watch --allow-net --allow-read --allow-env src/bin/agent.ts start",
    "dist": "deno task compile",
    "dist:local": "deno task compile",
    "publish": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts",
    "publish:local": "deno run --allow-write --allow-env --allow-sys --allow-read --allow-run publish.ts --local",
    "compile": "deno task compile:linux_x86 && deno task compile:linux_arm",
    "compile:linux_x86": "deno compile --allow-read --allow-write --allow-sys --allow-net --allow-env --allow-run --target x86_64-unknown-linux-gnu --output dist/bin/agent-linux-x64 src/bin/agent.ts",
    "compile:linux_arm": "deno compile --allow-read --allow-write --allow-sys --allow-net --allow-env --allow-run --target aarch64-unknown-linux-gnu --output dist/bin/agent-linux-arm64 src/bin/agent.ts"
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.23.0",
    "@inquirer/prompts": "npm:@inquirer/prompts@^5.0.1",
    "@std/archive": "jsr:@std/archive@^0.224.0",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.224.0",
    "@std/cli": "jsr:@std/cli@^0.224.0",
    "@std/fs": "jsr:@std/fs@^0.224.0",
    "@std/io": "jsr:@std/io@^0.224.0",
    "@std/log": "jsr:@std/log@^0.224.0",
    "@std/testing": "jsr:@std/testing@^0.224.0",
    "hono": "https://deno.land/x/hono@v4.2.9/mod.ts",
    "hono/types": "https://deno.land/x/hono@v4.2.9/types.ts",
    "moderndash": "npm:moderndash@^3.11.1",
    "commander": "npm:commander@^12.0.0",
    "zod": "npm:zod@^3.23.4"
  }
}
