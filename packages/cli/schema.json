{
  "$ref": "#/definitions/deployer",
  "definitions": {
    "deployer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "pattern": "^[A-Za-z0-9_@./#&+-]*$"
        },
        "providers": {
          "type": "object",
          "properties": {
            "deployer": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Deployer api key"
                }
              },
              "required": [
                "apiKey"
              ],
              "additionalProperties": false,
              "description": "Deployer provider config"
            },
            "cloudflare": {
              "type": "object",
              "properties": {
                "apiToken": {
                  "type": "string",
                  "description": "Cloudflare api key https://developers.cloudflare.com/fundamentals/api/get-started/create-token/"
                },
                "accountId": {
                  "type": "string",
                  "description": "Cloudflare account id https://developers.cloudflare.com/fundamentals/setup/find-account-and-zone-ids"
                }
              },
              "required": [
                "apiToken",
                "accountId"
              ],
              "additionalProperties": false,
              "description": "Cloudflare provider config"
            },
            "namecheap": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Namecheap api keyhttps://www.namecheap.com/support/api/intro/"
                },
                "apiUser": {
                  "type": "string",
                  "description": "Your Namecheap account username will act as API username"
                }
              },
              "required": [
                "apiKey",
                "apiUser"
              ],
              "additionalProperties": false,
              "description": "Hetzner provider config"
            },
            "hcloud": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Hetzner api key https://docs.hetzner.com/cloud/api/getting-started/generating-api-token/"
                }
              },
              "required": [
                "apiKey"
              ],
              "additionalProperties": false,
              "description": "Hetzner provider config"
            },
            "state": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "s3"
                  ],
                  "description": "Type of state provider, only s3 is supported at the moment"
                },
                "bucket": {
                  "type": "string",
                  "description": "Name of s3 bucket"
                },
                "region": {
                  "type": "string",
                  "description": "name of region, use auto for R2"
                },
                "endpoint": {
                  "type": "string",
                  "description": "s3 endpoint"
                },
                "accessKeyId": {
                  "type": "string",
                  "description": "access key id"
                },
                "secretAccessKey": {
                  "type": "string",
                  "description": "s3 access key"
                }
              },
              "required": [
                "type",
                "bucket",
                "region",
                "endpoint",
                "accessKeyId",
                "secretAccessKey"
              ],
              "additionalProperties": false,
              "description": "State provider config, only required when not using oss version"
            }
          },
          "additionalProperties": false
        },
        "dns": {
          "type": "object",
          "properties": {
            "cloudflare": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "not": {}
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "ttl": {
                            "type": "number",
                            "description": "TTL in seconds"
                          },
                          "proxied": {
                            "type": "boolean"
                          },
                          "comment": {
                            "type": "string"
                          },
                          "tags": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "branch": {
                            "type": "string"
                          },
                          "branchPattern": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "value"
                        ],
                        "additionalProperties": false
                      }
                    }
                  ]
                }
              }
            },
            "namecheap": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "not": {}
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "ttl": {
                            "type": "number",
                            "description": "TTL in seconds"
                          },
                          "branch": {
                            "type": "string"
                          },
                          "branchPattern": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "value"
                        ],
                        "additionalProperties": false
                      }
                    }
                  ]
                }
              }
            }
          },
          "additionalProperties": false
        },
        "buckets": {
          "type": "object",
          "properties": {
            "cloudflare": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "locationHint": {
                    "type": "string",
                    "enum": [
                      "apac",
                      "eeur",
                      "enam",
                      "weur",
                      "wnam"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "name",
        "providers"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}