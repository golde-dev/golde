{
  "$ref": "#/definitions/golde",
  "definitions": {
    "golde": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "pattern": "^[A-Za-z0-9_@./#&+-]*$"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "state": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "s3",
                  "description": "Type of state backend for s3 backed state"
                },
                "bucket": {
                  "type": "string",
                  "description": "Name of s3 bucket"
                },
                "region": {
                  "type": "string",
                  "description": "name of region, use auto for R2"
                },
                "endpoint": {
                  "type": "string",
                  "description": "s3 endpoint"
                },
                "accessKeyId": {
                  "type": "string",
                  "description": "access key id"
                },
                "secretAccessKey": {
                  "type": "string",
                  "description": "s3 access key"
                }
              },
              "required": [
                "type",
                "bucket",
                "region",
                "endpoint"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "fs",
                  "description": "Type of state backend"
                },
                "path": {
                  "type": "string",
                  "description": "relative path to lock file"
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            }
          ],
          "description": "State backend config, only required when not using oss version"
        },
        "providers": {
          "type": "object",
          "properties": {
            "golde": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Golde api key"
                }
              },
              "required": [
                "apiKey"
              ],
              "additionalProperties": false,
              "description": "Golde provider config"
            },
            "aws": {
              "type": "object",
              "properties": {
                "accessKeyId": {
                  "type": "string",
                  "description": "AWS access key id"
                },
                "secretAccessKey": {
                  "type": "string",
                  "description": "AWS secret access key"
                },
                "region": {
                  "type": "string",
                  "description": "AWS region to use when managing aws resources"
                }
              },
              "required": [
                "accessKeyId",
                "secretAccessKey"
              ],
              "additionalProperties": false,
              "description": "AWS provider config"
            },
            "docker": {
              "type": "object",
              "properties": {
                "registry": {
                  "type": "string",
                  "description": "Docker registry url"
                },
                "username": {
                  "type": "string",
                  "description": "Docker registry username"
                },
                "password": {
                  "type": "string",
                  "description": "Docker registry password"
                }
              },
              "required": [
                "registry",
                "username",
                "password"
              ],
              "additionalProperties": false,
              "description": "Docker provider config"
            },
            "cloudflare": {
              "type": "object",
              "properties": {
                "apiToken": {
                  "type": "string",
                  "description": "Cloudflare api key https://developers.cloudflare.com/fundamentals/api/get-started/create-token/"
                },
                "accountId": {
                  "type": "string",
                  "description": "Cloudflare account id https://developers.cloudflare.com/fundamentals/setup/find-account-and-zone-ids"
                }
              },
              "required": [
                "apiToken",
                "accountId"
              ],
              "additionalProperties": false,
              "description": "Cloudflare provider config"
            },
            "hcloud": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Hetzner API token https://docs.hetzner.com/cloud/api/getting-started/generating-api-token/"
                }
              },
              "required": [
                "apiKey"
              ],
              "additionalProperties": false,
              "description": "Hetzner provider config"
            }
          },
          "additionalProperties": false
        },
        "aws": {
          "type": "object",
          "properties": {
            "s3Bucket": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "branch": {
                    "type": "string"
                  },
                  "branchPattern": {
                    "type": "string"
                  },
                  "tags": {
                    "$ref": "#/definitions/golde/properties/tags"
                  },
                  "region": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "s3Object": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "branch": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branch"
                  },
                  "branchPattern": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branchPattern"
                  },
                  "tags": {
                    "$ref": "#/definitions/golde/properties/tags"
                  }
                },
                "additionalProperties": false
              }
            },
            "route53Record": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "not": {}
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "ttl": {
                            "type": "number",
                            "description": "TTL in seconds"
                          },
                          "proxied": {
                            "type": "boolean"
                          },
                          "comment": {
                            "type": "string"
                          },
                          "tags": {
                            "$ref": "#/definitions/golde/properties/tags"
                          },
                          "branch": {
                            "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branch"
                          },
                          "branchPattern": {
                            "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branchPattern"
                          }
                        },
                        "required": [
                          "value"
                        ],
                        "additionalProperties": false
                      }
                    }
                  ]
                }
              }
            },
            "iamRole": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "branch": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branch"
                  },
                  "branchPattern": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branchPattern"
                  },
                  "tags": {
                    "$ref": "#/definitions/golde/properties/tags"
                  },
                  "assumeRolePolicy": {
                    "type": "object",
                    "properties": {
                      "Version": {
                        "type": "string",
                        "enum": [
                          "2012-10-17"
                        ]
                      },
                      "Statement": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "Sid": {
                              "type": "string"
                            },
                            "Principal": {
                              "type": "object",
                              "properties": {
                                "AWS": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                },
                                "Service": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                },
                                "Federated": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                },
                                "CanonicalUser": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                }
                              },
                              "additionalProperties": false
                            },
                            "Action": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                }
                              ]
                            },
                            "Resource": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                }
                              ]
                            },
                            "Effect": {
                              "type": "string",
                              "enum": [
                                "Allow",
                                "Deny"
                              ]
                            }
                          },
                          "required": [
                            "Action",
                            "Effect"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "Version",
                      "Statement"
                    ],
                    "additionalProperties": false
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "inlinePolicy": {
                    "$ref": "#/definitions/golde/properties/aws/properties/iamRole/additionalProperties/properties/assumeRolePolicy"
                  },
                  "permissionsBoundaryArn": {
                    "type": "string"
                  },
                  "managedPoliciesArns": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/golde/properties/aws/properties/iamRole/additionalProperties/properties/permissionsBoundaryArn"
                    }
                  }
                },
                "required": [
                  "assumeRolePolicy"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "cloudflare": {
          "type": "object",
          "properties": {
            "dns": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "not": {}
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "ttl": {
                            "type": "number",
                            "description": "TTL in seconds"
                          },
                          "proxied": {
                            "type": "boolean"
                          },
                          "comment": {
                            "type": "string"
                          },
                          "tags": {
                            "$ref": "#/definitions/golde/properties/tags"
                          },
                          "branch": {
                            "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branch"
                          },
                          "branchPattern": {
                            "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branchPattern"
                          }
                        },
                        "required": [
                          "value"
                        ],
                        "additionalProperties": false
                      }
                    }
                  ]
                }
              }
            },
            "r2": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "branch": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branch"
                  },
                  "branchPattern": {
                    "$ref": "#/definitions/golde/properties/aws/properties/s3Bucket/additionalProperties/properties/branchPattern"
                  },
                  "locationHint": {
                    "type": "string",
                    "enum": [
                      "apac",
                      "eeur",
                      "enam",
                      "weur",
                      "wnam"
                    ]
                  },
                  "storageClass": {
                    "type": "string",
                    "enum": [
                      "Standard",
                      "InfrequentAccess"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}