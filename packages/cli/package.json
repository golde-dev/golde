{
  "name": "@tenacify/cli",
  "packageManager": "yarn@4.0.2",
  "version": "0.2.0",
  "type": "commonjs",
  "main": "./lib/index.js",
  "bin": {
    "deployer": "./lib/bin/deployer.js"
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "generateSchema": "node ./lib/bin/schema.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@tenacify/core": "^0.2.0",
    "commander": "^12.0.0",
    "dotenv": "16.4.5",
    "execa": "^8.0.1",
    "find-up": "^5.0.0",
    "glob": "^10.3.10",
    "pino": "^8.19.0",
    "tar": "^6.2.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.4"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.24",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^20.11.20",
    "@types/tar": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.57.0",
    "vitest": "^1.3.1"
  }
}
