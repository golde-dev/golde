{
  "extends": "@chyzwar/tsconfig/api.json", 
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "tsBuildInfoFile": "./lib/buildInfo.json",
    "types": [
      "node",
      "iarna__toml"
    ]
  },
  "include": [
    "src/**/*"  
  ],
  "references": [
    {"path": "../core"}
  ] 
}