{
  "name": "@tenacify/core",
  "packageManager": "yarn@4.0.2",
  "version": "0.2.0",
  "type": "commonjs",
  "main": "./lib/index.js",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.25",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
