{
  "name": "@tenacify/core",
  "packageManager": "yarn@4.0.2",
  "version": "0.2.0",
  "type": "commonjs",
  "main": "./lib/index.js",
  "scripts": {
    "lint": "eslint . --ext .ts,.js,.tsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx --fix",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.515.0",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@chyzwar/eslint-config": "^0.2.24",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
